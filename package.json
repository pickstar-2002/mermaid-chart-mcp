{
  "name": "@pickstar-2002/mermaid-chart-mcp",
  "version": "1.0.1",
  "description": "🎨 A powerful Mermaid chart rendering service with MCP (Model Context Protocol) support for AI assistants",
  "main": "dist/index.js",
  "bin": {
    "mermaid-chart-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "clean": "rimraf dist",
    "prepublishOnly": "npm run build",
    "mcp": "node dist/index.js --mcp",
    "server": "node dist/index.js"
  },
  "keywords": [
    "mcp",
    "mermaid",
    "chart",
    "diagram",
    "ai"
  ],
  "author": "pickstar-2002",
  "license": "MIT",
  "homepage": "https://github.com/pickstar-2002/mermaid-chart-mcp#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pickstar-2002/mermaid-chart-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/pickstar-2002/mermaid-chart-mcp/issues"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^0.4.0",
    "@mermaid-js/mermaid-cli": "^10.6.1",
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "fs-extra": "^11.2.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.10.5",
    "@types/uuid": "^9.0.7",
    "typescript": "^5.3.3",
    "ts-node": "^10.9.2",
    "rimraf": "^5.0.5"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
