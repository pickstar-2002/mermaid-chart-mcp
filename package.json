  "repository": {
    "type": "git",
    "url": "https://github.com/pickstar-2002/mermaid-chart-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/pickstar-2002/mermaid-chart-mcp/issues"
  },
  "homepage": "https://github.com/pickstar-2002/mermaid-chart-mcp#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^0.5.0",
    "axios": "^1.6.2",
    "form-data": "^4.0.0",
    "fs-extra": "^11.2.0",
    "joi": "^17.11.0",
    "puppeteer": "^21.6.1",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.19.10",
    "@types/uuid": "^9.0.7",
    "tsx": "^4.6.2",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
